# Garage RPC secret — generate with: openssl rand -hex 32
GARAGE_RPC_SECRET=replace_with_openssl_rand_hex_32

# Garage admin/metrics tokens — generate with: openssl rand -base64 32
GARAGE_ADMIN_TOKEN=replace_with_openssl_rand_base64_32
GARAGE_METRICS_TOKEN=replace_with_openssl_rand_base64_32

# S3 access credentials Garage will autocreate on first boot (--single-node mode).
# Use these in Nextcloud's setup wizard.
GARAGE_DEFAULT_ACCESS_KEY=GKnextcloudaccesskey
GARAGE_DEFAULT_SECRET_KEY=replace_with_long_random_secret
GARAGE_DEFAULT_BUCKET=nextcloud

# Nextcloud admin (set during first-run setup, but seed them here)
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=replace_with_strong_password

# Postgres
POSTGRES_DB=nextcloud
POSTGRES_USER=nextcloud
POSTGRES_PASSWORD=replace_with_strong_password
