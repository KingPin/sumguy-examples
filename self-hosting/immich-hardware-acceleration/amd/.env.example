DB_PASSWORD=change_me_to_a_real_password
LIBRARY_PATH=/mnt/photos

# Find the right GIDs on YOUR host:
#   getent group video render
VIDEO_GID=44
RENDER_GID=104

# ROCm in containers is sensitive to host kernel + driver pairing.
# If `immich-machine-learning` fails on startup, fall back to the
# CPU/OpenVINO image (release-openvino) for ML and keep VAAPI for
# transcoding — that combination works on basically any modern AMD GPU.
