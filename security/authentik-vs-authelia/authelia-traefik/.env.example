TZ=America/New_York

# Authelia needs three secrets. Generate each with:
#   openssl rand -hex 32
#
# These are loaded from files in ./config/secrets/ — create that directory
# and drop one file per secret (no trailing newline):
#   mkdir -p config/secrets
#   openssl rand -hex 32 > config/secrets/JWT_SECRET
#   openssl rand -hex 32 > config/secrets/SESSION_SECRET
#   openssl rand -hex 32 > config/secrets/STORAGE_ENCRYPTION_KEY
#   chmod 600 config/secrets/*
