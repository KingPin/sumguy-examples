# Postgres
PG_USER=authentik
PG_DB=authentik
PG_PASS=replace-me-with-a-long-random-password

# Authentik secret key — generate with: openssl rand -base64 60 | tr -d '\n'
AUTHENTIK_SECRET_KEY=replace-me-with-a-long-random-secret

# Pin to a known release rather than 'latest' so worker/server match
AUTHENTIK_TAG=2024.10
